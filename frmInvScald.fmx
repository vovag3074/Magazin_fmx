  end
  object qKat: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select '
      '    K.NO_KAT,'
      '    K.NAZVAN,'
      '    K.SUM_SKID,'
      '    sum( T.CNT_MOD ) SUM_OF_CNT_MOD'
      'from MODEL_IN_SCLAD T'
      '   inner join MODEL_TABLE M on (T.NO_MOD = M.NO_MOD)'
      '   inner join KATEGORY_TABLE K on (M.NO_KAT = K.NO_KAT)'
      'where '
      '   ('
      '      (T.IS_VIT = :IV)'
      '   )'
      'group by K.NO_KAT, K.NAZVAN, K.SUM_SKID'
      'order by K.NAZVAN'
      '')
    Left = 32
    Top = 360
    ParamData = <
      item
        Name = 'IV'
        ParamType = ptInput
      end>
  end
  object qMod: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select MS.CNT_MOD, M.M_CENA, M.NAZVAN, M.NO_MOD'
      'from MODEL_IN_SCLAD MS'
      'inner join MODEL_TABLE M on (MS.NO_MOD = M.NO_MOD)'
      'where ((M.NO_KAT = :NK) and'
      '      (MS.IS_VIT = :IV) and'
      '      (MS.CNT_MOD > 0))'
      'order by M.NAZVAN  '
      '')
    Left = 72
    Top = 360
    ParamData = <
      item
        Name = 'NK'
        ParamType = ptInput
      end
      item
        Name = 'IV'
        ParamType = ptInput
      end>
  end
  object qZakList: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select Z.CODE_ZAK,'
      '       Z.NO_ZAK,'
      '       AG.AG_NAME,'
      '       ST.ST_NAME,'
      '       Z.CNT_MOD'
      'from ZAKAZ_LIST Z'
      'inner join AGENTS AG on (Z.NO_AGN = AG.NO_AGN)'
      'inner join SITY_TABLE ST on (AG.NO_SITY = ST.NO_ST)'
      'where ((Z.IS_MOVE = 1) and'
      '      (Z.IS_PROD = 0) and'
      '      (Z.DATA_END >= '#39'now'#39'))'
      'order by AG.AG_NAME, ST.ST_NAME  '
      '')
    Left = 568
    Top = 248
  end
  object qSize: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select distinct'
      '    MSS.N0_MSIS,'
      '    MSS.CNT_MOD,'
      '    SM.NO_SIZE,'
      '    EMT.NO_ETS,'
      '    SM.NO_SMT'
      'from SIZE_MOD_TABLE SM'
      'inner join MODEL_SIZE_TABLE MS on (SM.NO_SMT = MS.NO_SIZE)'
      
        'inner join MODEL_SIZE_IN_SCLAD MSS on (MS.NO_MST = MSS.NO_MOD_SI' +
        'ZE)'
      'inner join MODEL_TABLE M on (MS.NO_MOD = M.NO_MOD)'
      'inner join KATEGORY_TABLE K on (M.NO_KAT = K.NO_KAT)'
      'inner join ENABLE_TYPE_SIZE EMT on (K.NO_TYPE = EMT.NO_TYPE)'
      'inner join SIZE_MOD_TABLE on (EMT.NO_SIZE = SM.NO_SMT)'
      'where ((MS.NO_MOD = :NM) and'
      '      (MSS.IS_VIT = :IV) and'
      '      (MS.IS_ENABLE = 1))'
      'order by 3  '
      '')
    Left = 297
    Top = 376
    ParamData = <
      item
        Name = 'NM'
        ParamType = ptInput
      end
      item
        Name = 'IV'
        ParamType = ptInput
      end>
  end
  object qModZak: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT COUNT(MST.NO_MST) CNT_NO_MST,'
      '       AGENTS.FULL_NAME_STD'
      'FROM AGENTS'
      'INNER JOIN ZAKAZ_LIST ZL ON (AGENTS.NO_AGN = ZL.NO_AGN)'
      'INNER JOIN ZAKAZ_LIST_DETAIL ZLD ON (ZL.NO_ZAK = ZLD.NO_ZAKAZ)'
      
        'INNER JOIN MODEL_SIZE_TABLE MST ON (ZLD.NO_MOD_SIZE = MST.NO_MST' +
        ')'
      'WHERE ((ZL.IS_MOVE = 1) AND'
      '      (ZL.IS_PROD = 0) AND'
      '      (ZL.DATA_END >= '#39'now'#39') AND'
      '      (MST.NO_MOD = :NM))'
      'GROUP BY AGENTS.FULL_NAME_STD'
      'ORDER BY AGENTS.FULL_NAME_STD  '
      '')
    Left = 576
    Top = 392
    ParamData = <
      item
        Name = 'NM'
        ParamType = ptInput
      end>
  end
