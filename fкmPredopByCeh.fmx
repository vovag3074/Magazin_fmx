  object qRead: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT lpc.NO_CEH,'
      'SUM(LPC.SUM_PRED) SUM_OF_SUM_PRED'
      'FROM LOG_PRED_BY_CEH LPC'
      'WHERE ((LPC.NO_AGN = :NG) AND'
      '      (LPC.DATA_POL = :DP))'
      'GROUP by lpc.NO_CEH'
      '')
    Left = 128
    Top = 64
    ParamData = <
      item
        Name = 'NG'
        ParamType = ptInput
      end
      item
        Name = 'DP'
        ParamType = ptInput
      end>
  end
  object qSum: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT SUM(LP.SUM_PRED) SUM_OF_SUM_PRED'
      'FROM LOG_PRED_AGN LP'
      'WHERE ((LP.NO_AGN = :NG) AND'
      '      (LP.DATA_PRED = :DP) AND'
      '      (LP.IS_VIRT = 0))   '
      '')
    Left = 224
    Top = 64
    ParamData = <
      item
        Name = 'NG'
        ParamType = ptInput
      end
      item
        Name = 'DP'
        ParamType = ptInput
      end>
  end
end
