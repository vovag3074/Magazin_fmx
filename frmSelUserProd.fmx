  object qList: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT DISTINCT LP.DATA_PROD,'
      '       AGN.FULL_NAME_STD,'
      '       AGN.NO_AGN'
      'FROM AGENTS AGN'
      'INNER JOIN LOG_PROD_TABLE LP ON (AGN.NO_AGN = LP.NO_AGN)'
      'WHERE ((LP.DATA_PROD = :DP))'
      'ORDER BY AGN.FULL_NAME_STD  ')
    Left = 48
    Top = 88
    ParamData = <
      item
        Name = 'DP'
        ParamType = ptInput
      end>
  end
end
