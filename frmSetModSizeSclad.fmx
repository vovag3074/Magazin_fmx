  object qInfo: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select MT.NAZVAN'
      'from MODEL_TABLE MT'
      'where MT.NO_MOD = :NM  ')
    Left = 16
    Top = 104
    ParamData = <
      item
        Name = 'NM'
        ParamType = ptInput
      end>
  end
  object qList: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    FetchOptions.AssignedValues = [evAutoFetchAll]
    SQL.Strings = (
      'SELECT S.NO_SIZE,'
      '       MS.CNT_MOD,'
      '       M.NO_MST'
      'FROM MODEL_SIZE_TABLE M'
      'INNER JOIN SIZE_MOD_TABLE S ON (M.NO_SIZE = S.NO_SMT)'
      
        'LEFT OUTER JOIN MODEL_SIZE_IN_SCLAD MS ON (M.NO_MST = MS.NO_MOD_' +
        'SIZE)'
      'WHERE ((M.NO_MOD = :NM) AND'
      '      (M.IS_ENABLE = 1))'
      'ORDER BY S.NO_SIZE  ')
    Left = 16
    Top = 168
    ParamData = <
      item
        Name = 'NM'
        ParamType = ptInput
      end>
  end
  object qUpd: TFDCommand
    Connection = fmMain.IBC
    Transaction = fmMain.IBT
    CommandText.Strings = (
      'execute procedure UPD_SIZE_IN_SCLAD(:NO_MSIS, :CNT_SIZE, :ISVIT)')
    ParamData = <
      item
        Name = 'NO_MSIS'
        ParamType = ptInput
      end
      item
        Name = 'CNT_SIZE'
        ParamType = ptInput
      end
      item
        Name = 'ISVIT'
        ParamType = ptInput
      end>
    Left = 16
    Top = 225
  end
