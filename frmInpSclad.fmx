  object qList: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    FetchOptions.AssignedValues = [evMode]
    FetchOptions.Mode = fmAll
    SQL.Strings = (
      'select '
      '    m.nazvan m_nazvan,'
      '    k.nazvan k_nazvan,'
      '    count( l.no_size_mod ) count_of_no_size_mod,'
      '    s.no_mod'
      'from model_size_table s'
      '   inner join log_move_table l on (s.no_mst = l.no_size_mod)'
      '   inner join model_table m on (s.no_mod = m.no_mod)'
      '   inner join kategory_table k on (m.no_kat = k.no_kat)'
      'where '
      '   ('
      '      (l.is_ret = 0)'
      '   )'
      'group by m.nazvan, k.nazvan, s.no_mod'
      'order by k.nazvan, m.nazvan'
      '')
    Left = 24
    Top = 320
  end
  object qReadZakaz: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select AG.AG_NAME,'
      '       S.ST_NAME,'
      '       T.NO_TMZ,'
      '       sum(Z.CNT_MOD) SUM_OF_CNT_MOD,'
      '       Z.CODE_ZAK'
      'from ZAKAZ_LIST Z'
      'inner join TMP_MOVE_ZAKAZ T on (Z.NO_ZAK = T.NO_ZAK)'
      'inner join AGENTS AG on (Z.NO_AGN = AG.NO_AGN)'
      'inner join SITY_TABLE S on (AG.NO_SITY = S.NO_ST)'
      'group by AG.AG_NAME, S.ST_NAME, T.NO_TMZ, Z.CODE_ZAK'
      'order by T.NO_TMZ desc  '
      '')
    Left = 72
    Top = 320
  end
  object qDet: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select SM.NO_SIZE,'
      '       count(S.NO_MOD) CNT_MOD,'
      '       M.NO_MOD,'
      '       L.NO_SIZE_MOD'
      'from MODEL_TABLE M'
      'inner join MODEL_SIZE_TABLE S on (M.NO_MOD = S.NO_MOD)'
      'inner join LOG_MOVE_TABLE L on (S.NO_MST = L.NO_SIZE_MOD)'
      'inner join SIZE_MOD_TABLE SM on (S.NO_SIZE = SM.NO_SMT)'
      'where ((L.IS_RET = 0) and'
      '      (M.NO_MOD = :NM))'
      'group by SM.NO_SIZE, M.NO_MOD, L.NO_SIZE_MOD'
      'order by 1  '
      '')
    Left = 120
    Top = 320
    ParamData = <
      item
        Name = 'NM'
        ParamType = ptInput
      end>
  end
