  object qTEnable: TFDQuery
    Connection = IBC_Read
    Transaction = IBT_Read
    SQL.Strings = (
      'select'
      '    T.BAR_CODE,'
      '    SM.NO_SIZE'
      'from SUB_MODEL_SIZE SM'
      
        'inner join ENABLE_MOD_SIZE_BY_TYPE EMT on (SM.NO_SMS = EMT.NO_MO' +
        'D_SIZE)'
      'inner join TYPE_MOD_LIST T on (EMT.NO_TYPE = T.NO_TML)'
      'order by SM.NO_SIZE  '
      '')
    Left = 496
    Top = 24
  end
