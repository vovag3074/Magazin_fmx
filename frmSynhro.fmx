  object qRMod: TFDQuery
    Connection = IBC_Read
    Transaction = IBT_Read
    FetchOptions.AssignedValues = [evMode, evRecordCountMode]
    FetchOptions.Mode = fmAll
    FetchOptions.RecordCountMode = cmTotal
    SQL.Strings = (
      'SELECT '
      '    K.NAZVAN K_NAME,'
      '    M.NAZVAN M_NAME,'
      '    M.Barcode,'
      '    M.M_CENA,'
      '    M.IS_DEL'
      'FROM MODEL_TABLE M'
      '   INNER JOIN KATEGORY_TABLE K ON (M.NO_KAT = K.NO_KAT)'
      'WHERE '
