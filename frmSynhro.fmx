  object qRCode: TFDQuery
    Connection = IBC_Read
    Transaction = IBT_Read
    FetchOptions.AssignedValues = [evMode, evRecordCountMode]
    FetchOptions.Mode = fmAll
    FetchOptions.RecordCountMode = cmTotal
    SQL.Strings = (
      'select ZM.NO_SIZE,'
      '       S.UN_SM,'
      '       M.NAZVAN M_NAZVAN,'
      '       M.BARCODE,'
      '       K.NAZVAN K_NAZVAN,'
      '       S.IS_ENABLE'
      'from SUB_MODEL_SIZE ZM'
      'inner join SUB_MODEL_TABLE S on (ZM.NO_SMS = S.SM_SIZE)'
      'inner join MODEL_TABLE M on (S.NO_MOD = M.NO_MOD)'
      'inner join KATEGORY_TABLE K on (M.NO_KAT = K.NO_KAT)'
      'where M.IS_MAT = 0'
      'order by K.NAZVAN, M.NAZVAN  '
      '')
    Left = 296
    Top = 24
  end
