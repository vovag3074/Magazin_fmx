        'IS_SKIDKA, BAR_CODE)'
      
        'values (:NO_SITY, :PRED_VAL, :AG_NAME, :AG_DOP, :IS_DEL, :IS_SKI' +
        'DKA, :BAR_CODE)'
      '')
    ParamData = <
      item
        Name = 'NO_SITY'
        ParamType = ptInput
      end
      item
        Name = 'PRED_VAL'
        ParamType = ptInput
      end
      item
        Name = 'AG_NAME'
        ParamType = ptInput
      end
      item
        Name = 'AG_DOP'
