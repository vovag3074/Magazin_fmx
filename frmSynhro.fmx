  object qExpZak: TFDQuery
    Connection = IBC_Read
    Transaction = IBT_Read
    SQL.Strings = (
      'select ZK.BAR_CODE,'
      '       sum(ZD.CNT_MOD_SIZE) CNT_MOD,'
      '       AG.BAR_CODE AGENT_CODE'
      'from ZAKAZ_DET_TABLE ZD'
      'inner join ZAKAZY_TABLE ZK on (ZD.NO_ZAK = ZK.NO_ZAK)'
      'inner join AGENTS AG on (ZK.NO_AGN = AG.NO_AGN)'
      'where ((ZK.DATA_END >= '#39'now'#39') and'
      '      (ZK.MY_STATUS = 4))'
      'group by ZK.BAR_CODE, AG.BAR_CODE  '
      '')
    Left = 496
    Top = 72
  end
