  object qRead: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select AG.AG_DOLG,'
      '       AG.AG_PRED,'
      '       AG.AG_BANK_PRED,'
      '       AG.PRED_VAL'
      'from AGENTS AG'
      'where AG.NO_AGN = :NG '
      '')
    Left = 188
    Top = 320
    ParamData = <
      item
        Name = 'NG'
        ParamType = ptInput
      end>
  end
  object qClose: TFDCommand
    Connection = fmMain.IBC
    Transaction = fmMain.IBT
    CommandText.Strings = (
      'update LOG_PROD_TABLE'
      'set IS_TEMP = 0'
      'where IS_TEMP = 1'
      '')
    Left = 244
    Top = 328
  end
