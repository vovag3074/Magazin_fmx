      'from LOG_MOVE_TABLE LMT'
      
        'inner join MODEL_SIZE_TABLE MST on (LMT.NO_SIZE_MOD = MST.NO_MST' +
        ')'
      'inner join MODEL_TABLE MT on (MST.NO_MOD = MT.NO_MOD)'
      'inner join KATEGORY_TABLE KT on (MT.NO_KAT = KT.NO_KAT)'
      'inner join SIZE_MOD_TABLE ST on (MST.NO_SIZE = ST.NO_SMT)'
      'where ((LMT.IS_RET = 0))'
      'order by MST.UN_CODE  '
      '')
    Left = 80
    Top = 88
  end
  object qMod2: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select distinct MST.UN_CODE,'
      '                MT.NAZVAN M_NAZVAN,'
      '                MT.BARCODE,'
      '                K.NAZVAN K_NAZVAN,'
      '                SM.NO_SIZE,'
      '                MT.M_CENA'
      'from KATEGORY_TABLE K'
      'inner join MODEL_TABLE MT on (K.NO_KAT = MT.NO_KAT)'
      'inner join MODEL_SIZE_TABLE MST on (MT.NO_MOD = MST.NO_MOD)'
      'inner join ZAKAZ_LIST_DETAIL ZD on (MST.NO_MST = ZD.NO_MOD_SIZE)'
      'inner join ZAKAZ_LIST Z on (ZD.NO_ZAKAZ = Z.NO_ZAK)'
      'inner join SIZE_MOD_TABLE SM on (MST.NO_SIZE = SM.NO_SMT)'
      'where ((Z.DATA_END >= '#39'now'#39') and'
      '      (Z.IS_MOVE = 1))'
      'order by MST.UN_CODE  '
      '')
    Left = 112
    Top = 88
  end
  object qExp: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select L.NO_SIZE_MOD, L.DATA_TIME_MOVE, MS.UN_CODE'
      'from MODEL_SIZE_TABLE MS'
      'inner join LOG_MOVE_TABLE L on (MS.NO_MST = L.NO_SIZE_MOD)'
      'where L.IS_RET = 0'
      'order by L.DATA_TIME_MOVE  '
      '')
    Left = 144
    Top = 88
  end
  object qExpZak: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT '
      '    AG.BAR_CODE,'
      '    ZK.CODE_ZAK,'
      '    ZK.CNT_MOD'
      'FROM ZAKAZ_LIST ZK'
      '   INNER JOIN AGENTS AG ON (ZK.NO_AGN = AG.NO_AGN)'
      'WHERE '
      '   ('
      '      (ZK.DATA_END >= '#39'now'#39') '
      '    and'
      '      (ZK.IS_MOVE = 1)'
      '   )'
      'ORDER BY ZK.CODE_ZAK'
      '')
    Left = 216
    Top = 88
  end
  object qExpZalList: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT '
      '    ZK.CODE_ZAK,'
      '    ZLD.CNT_MOD,'
      '    MST.UN_CODE'
      'FROM MODEL_SIZE_TABLE MST'
      
        '   INNER JOIN ZAKAZ_LIST_DETAIL ZLD ON (MST.NO_MST = ZLD.NO_MOD_' +
        'SIZE)'
      '   INNER JOIN ZAKAZ_LIST ZK ON (ZLD.NO_ZAKAZ = ZK.NO_ZAK)'
      'WHERE '
      '   ('
      '      (ZK.DATA_END >= '#39'now'#39') '
      '    and'
      '      (ZK.IS_MOVE = 1)'
      '   )'
      'ORDER BY ZK.CODE_ZAK'
      '')
    Left = 256
    Top = 88
  end
  object qTypeKat: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select TM.NAME_TYPE,'
      '       TM.CODE_TYPE'
      'from TYPE_MOD TM'
      'order by TM.NAME_TYPE'
      '')
    Left = 328
    Top = 88
  end
  object qExpKat: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select K.NAZVAN,'
      '       K.SUM_SKID,'
      '       K.UIN_KAT,'
      '       TM.CODE_TYPE'
      'from TYPE_MOD TM'
      'inner join KATEGORY_TABLE K on (TM.NO_TM = K.NO_TYPE)'
      'order by K.NAZVAN  '
      '')
    Left = 376
    Top = 88
  end
  object qExpUser: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select distinct AG.BAR_CODE AG_CODE,'
      '                AG.AG_NAME,'
      '                ST.ST_NAME,'
      '                ST.BAR_CODE SITY_CODE,'
      '                AG.AG_DOP,'
      '                AG.IS_SKIDKA,'
      '                VT.NAZVAN'
      'from VALUT_TABLE VT'
      'inner join AGENTS AG on (VT.NO_VAL = AG.PRED_VAL)'
      'inner join ZAKAZ_LIST ZK on (AG.NO_AGN = ZK.NO_AGN)'
      'inner join SITY_TABLE ST on (AG.NO_SITY = ST.NO_ST)'
      'where ((ZK.DATA_END >= '#39'now'#39') and'
      '      (ZK.IS_MOVE = 1))   '
      '')
    Left = 424
    Top = 88
  end
end
