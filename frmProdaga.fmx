  object qUsr: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select count(LP.NO_MOD_SIZE) COUNT_OF_NO_MOD_SIZE,'
      '       AG.AG_NAME,'
      '       V.NAZVAN,'
      '       LP.NO_AGN,'
      '       AG.AG_DOLG,'
      '       sum(LP.CENA_PROD) SUM_TOV,'
      '       sum(LP.OPLATA) SUM_OPL,'
      '       S.ST_NAME,'
      '       AG.IS_SKIDKA,'
      '       LOP.DOP_OPIS,'
      '       (AG.AG_PRED + AG.AG_BANK_PRED) AG_PRED'
      'from SITY_TABLE S'
      'inner join AGENTS AG on (S.NO_ST = AG.NO_SITY)'
      'inner join LOG_PROD_TABLE LP on (AG.NO_AGN = LP.NO_AGN)'
      'left outer join LOG_OTP_AGN LOP on ((AG.NO_AGN = LOP.NO_AGN) and'
      '      (LOP.DATA_OTP = :SD))'
      'inner join VALUT_TABLE V on (AG.PRED_VAL = V.NO_VAL)'
      'where ((LP.DATA_PROD = :SD) and'
      '      (LP.IS_TEMP = 0))'
      
        'group by AG.AG_NAME, V.NAZVAN, LP.NO_AGN, S.ST_NAME, AG.AG_DOLG,' +
        ' AG.IS_SKIDKA, LOP.DOP_OPIS, AG_PRED'
      'order by AG.AG_NAME  '
      '')
    Left = 72
    Top = 240
    ParamData = <
      item
        Name = 'SD'
        ParamType = ptInput
      end>
  end
  object qPred: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT (AG.FULL_NAME_STD) AG_NAME,'
      '                          AG.NO_AGN,'
      '                          LP.NO_PRGN,'
      '                          LP.POL_PRED,'
      '                          LP.SUM_PRED'
      'FROM AGENTS AG'
      'INNER JOIN LOG_PRED_AGN LP ON (AG.NO_AGN = LP.NO_AGN)'
      'WHERE ((LP.DATA_PRED = :DS) AND'
      '      (LP.IS_VIRT = 0))'
      'ORDER BY AG.AG_NAME'
      '')
    Left = 128
    Top = 240
    ParamData = <
      item
        Name = 'DS'
        ParamType = ptInput
      end>
  end
  object qPredBank: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select (AG.AG_NAME || '#39' '#39' || ST.ST_NAME) AG_NAME,'
      '                                         LP.NO_PRGN,'
      '                                         LP.POL_PRED,'
      '                                         LP.SUM_PRED'
      'from AGENTS AG'
      'inner join LOG_PRED_AGN LP on (AG.NO_AGN = LP.NO_AGN)'
      'inner join SITY_TABLE ST on (AG.NO_SITY = ST.NO_ST)'
      'where ((LP.DATA_PRED = :DS) and (LP.IS_VIRT = 1))'
      'order by ST.ST_NAME, AG.AG_NAME  ')
    Left = 128
    Top = 296
    ParamData = <
      item
        Name = 'DS'
        ParamType = ptInput
      end>
  end
  object qSumSend: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select VT.NAZVAN,'
      '       sum(LS.SUM_SND) SUM_OF_SUM_SND'
      'from LOG_SEND_CASHE_BAZ LS'
      'inner join VALUT_TABLE VT on (LS.NO_VAL = VT.NO_VAL)'
      'where ((LS.DATA_SND = :DS))'
      'group by VT.NAZVAN'
      '')
    Left = 128
    Top = 360
    ParamData = <
      item
        Name = 'DS'
        ParamType = ptInput
      end>
  end
  object qMod: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select M.NAZVAN M_NAZVAN,'
      '       sum(LP.CENA_PROD) SUM_PROD,'
      '       sum(LP.OPLATA) OPLATA,'
      '       LP.CENA_PROD,'
      '       K.NAZVAN K_NAZVAN,'
      '       count(LP.NO_LPT) COUNT_OF_NO_LPT,'
      '       MS.NO_MOD'
      'from MODEL_SIZE_TABLE MS'
      'inner join LOG_PROD_TABLE LP on (MS.NO_MST = LP.NO_MOD_SIZE)'
      'inner join MODEL_TABLE M on (MS.NO_MOD = M.NO_MOD)'
      'inner join KATEGORY_TABLE K on (M.NO_KAT = K.NO_KAT)'
      'where ((LP.NO_AGN = :NG) and'
      '      (LP.DATA_PROD = :SD) and'
      '      (LP.IS_TEMP = 0))'
      'group by M.NAZVAN, LP.CENA_PROD, K.NAZVAN, MS.NO_MOD'
      'order by K.NAZVAN, M.NAZVAN  '
      '')
    Left = 132
    Top = 414
    ParamData = <
      item
        Name = 'NG'
        ParamType = ptInput
      end
      item
        Name = 'SD'
        ParamType = ptInput
      end>
  end
  object qLogAg: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select first(20) DATA_PROD,'
      '       COUNT_OF_NO_MOD_SIZE,'
      '       SUM_OF_CENA_PROD,'
      '       OPERATION, '
      '       LOG_DOP,'
      '       TYPE_OP'
      'from LOG_IN_OUT_AGENT(:NG)'
      'order by DATA_PROD desc'
      '')
    Left = 188
    Top = 414
    ParamData = <
      item
        Name = 'NG'
        ParamType = ptInput
      end>
  end
  object qLOpl: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT NAZVAN,'
      '        CENA_PROD,'
      '        OPLATA,'
      '        DATA_PROD,'
      '        NO_LPT,'
      '        DATA_OPL,'
      '        IS_PRED,'
      '        IS_VIRT'
      ' FROM GET_HISTORY_PROD_BY_OPLATA(:NG)'
      '')
    Left = 254
    Top = 408
    ParamData = <
      item
        Name = 'NG'
        ParamType = ptInput
      end>
  end
