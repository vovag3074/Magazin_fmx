  object qDataPol: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select first (20) distinct LP.DATA_PROD'
      'from LOG_PROD_TABLE LP'
      'where ((LP.DATA_PROD <= current_date))'
      'order by LP.DATA_PROD desc  ')
    Left = 408
    Top = 408
  end
  object qInsPol: TFDCommand
    Connection = fmMain.IBC
    Transaction = fmMain.IBT
    CommandText.Strings = (
      'update LOG_PRED_AGN'
      'set POL_PRED = :POL_PRED'
      'where (NO_PRGN = :NO_PRGN)'
      '')
    ParamData = <
      item
        Name = 'POL_PRED'
        ParamType = ptInput
      end
      item
        Name = 'NO_PRGN'
        ParamType = ptInput
      end>
    Left = 488
    Top = 408
  end
  object qMoveProd: TFDCommand
    Connection = fmMain.IBC
    Transaction = fmMain.IBT
    CommandText.Strings = (
      'execute procedure MOVE_PROD(:NO_AGN, :OLD_DATA, :NEW_DATA)'
      '')
    ParamData = <
