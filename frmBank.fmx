        Name = 'MB'
        ParamType = ptInput
      end>
  end
  object qUsr: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT SUM_OPL,'
      '       DOP_STR,'
      '       AG_NAME,'
      '       ST_NAME,'
      '       LBO,'
      '       NO_AG,'
      '       DATA_NAK,'
      '       KURS_VAL,'
      '       VSUM_OPL'
      'FROM RET_INFO_BANK_OPL(:SD, :MY, :MB)  '
      ''
      '')
    Left = 240
    Top = 560
    ParamData = <
      item
        Name = 'SD'
        ParamType = ptInput
