  object qBank: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'select distinct LB.MY_BANK'
      'from LOG_BANK_OPLATA LB'
      'where ((LB.DATA_POL = :SD))'
      'order by LB.MY_BANK  ')
    Left = 24
    Top = 552
    ParamData = <
      item
        Name = 'SD'
        ParamType = ptInput
      end>
  end
  object qPol: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT DISTINCT LB.MY_USER'
      'FROM LOG_BANK_OPLATA LB'
      'WHERE ((LB.DATA_POL = :SD) AND'
      '      (LB.MY_BANK = :MB))'
      'ORDER BY LB.MY_USER  ')
    Left = 80
    Top = 552
    ParamData = <
      item
        Name = 'SD'
        ParamType = ptInput
      end
      item
        Name = 'MB'
        ParamType = ptInput
      end>
  end
  object qSumBank: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      ' SELECT SUM(LB.SUM_OPL) SUM_OF_SUM_OPL,'
      '       SUM(LB.VSUM_OPL) SUM_OF_VSUM_OPL'
      'FROM LOG_BANK_OPLATA LB'
      'WHERE ((LB.DATA_POL = :SD) AND'
      '      (LB.MY_BANK = :MB))')
    Left = 136
    Top = 560
    ParamData = <
      item
        Name = 'SD'
        ParamType = ptInput
      end
      item
        Name = 'MB'
        ParamType = ptInput
      end>
  end
  object qSumPol: TFDQuery
    Connection = fmMain.IBC
    Transaction = fmMain.IBT_Read
    SQL.Strings = (
      'SELECT SUM(LB.SUM_OPL) SUM_OF_SUM_OPL,'
      '       SUM(LB.VSUM_OPL) SUM_OF_VSUM_OPL'
      'FROM LOG_BANK_OPLATA LB'
      'WHERE (((LB.DATA_POL = :SD) AND'
      '      (LB.MY_USER = :MU)) AND'
      '      (LB.MY_BANK = :MB))   ')
    Left = 192
    Top = 560
