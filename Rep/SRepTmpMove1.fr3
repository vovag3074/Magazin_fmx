    <TfrxFDQuery Name="qTMove" UserName="qTMove" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select&#13;&#10;    m.nazvan m_nazvan,&#13;&#10;    k.nazvan k_nazvan,&#13;&#10;    m.m_cena,&#13;&#10;    count( m.no_mod ) count_of_no_mod&#13;&#10;from kategory_table k&#13;&#10;   inner join model_table m on (k.no_kat = m.no_kat)&#13;&#10;   inner join model_size_table ms on (m.no_mod = ms.no_mod)&#13;&#10;   inner join log_move_table lm on (ms.no_mst = lm.no_size_mod)&#13;&#10;where&#13;&#10;   (&#13;&#10;      (lm.is_ret = 0)&#13;&#10;   )&#13;&#10;group by m.nazvan, k.nazvan, m.m_cena&#13;&#10;order by k.nazvan, m.nazvan" PropData="05704C65667402540470546F7002600A506172616D65746572730100"/>
