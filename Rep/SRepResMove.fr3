<TfrxReport Version="2025.2.2" DotMatrixReport="False" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="По умолчанию" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="46113,4076844792" ReportOptions.Description.Text="" ReportOptions.LastChange="46113,4697906481" ReportOptions.IsFMXReport="True" ScriptLanguage="PascalScript" ScriptText.Text="var SD, ED: tDate;&#13;&#10;    I : String;&#13;&#10;&#13;&#10;&#13;&#10;procedure dpOnActivate(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  eSD.Date:=now;&#13;&#10;  eED.Date:=now;&#13;&#10;  eNo.Items.Clear;&#13;&#10;  qFab.Open;&#13;&#10;  qFab.First;&#13;&#10;  repeat&#13;&#10;   eNo.Items.Add(qFab.FieldByName('CODE_FAB').Value);&#13;&#10;   qfab.Next;&#13;&#10;  until qFab.Eof;&#13;&#10;  qSS.Open;&#13;&#10;  eSD.Date:=qSS.FieldByName('START_BAZAR').Value;&#13;&#10;  eED.Date:=qSS.FieldByName('END_BAZAR').Value;&#13;&#10;  qSS.Close;&#13;&#10;  qFab.Close;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure Button2OnClick(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10; SD:=eSD.Date;&#13;&#10; ED:=eEd.Date;&#13;&#10; I:=eNo.Items[eNo.ItemIndex];&#13;&#10; dp.ModalResult:=mrOK;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10; qLog.Close;&#13;&#10; qLog.ParamByName('SD').Value := SD;&#13;&#10; qLog.ParamByName('ED').Value := ED;&#13;&#10; qLog.ParamByName('NC').Value := I;&#13;&#10; qLog.Open;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" PropData="">
  <TfrxDataPage Name="Data" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxFDQuery Name="qSS" UserName="qSS" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="SELECT END_BAZAR,&#13;&#10;       START_BAZAR&#13;&#10;FROM GET_DIAPAZON_BAZAR" PropData="05704C656674024C0470546F70023C0A506172616D65746572730100"/>
    <TfrxFDQuery Name="qFab" UserName="qFab" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="SELECT DISTINCT FT.CODE_FAB&#13;&#10;FROM FAB_TABLE FT&#13;&#10;ORDER BY 1" PropData="05704C6566740388000470546F70023C0A506172616D65746572730100"/>
    <TfrxFDQuery Name="qLog" UserName="qLog" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select M.NAZVAN M_NAZVAN,&#13;&#10;       K.NAZVAN K_NAZVAN,&#13;&#10;       M.M_CENA,&#13;&#10;       count(M.NO_MOD) COUNT_OF_NO_MOD&#13;&#10;from MODEL_SIZE_TABLE MS&#13;&#10;inner join LOG_MOVE_TABLE_2 LM on (MS.NO_MST = LM.NO_SIZE_MOD)&#13;&#10;inner join MODEL_TABLE M on (MS.NO_MOD = M.NO_MOD)&#13;&#10;inner join KATEGORY_TABLE K on (M.NO_KAT = K.NO_KAT)&#13;&#10;where ((LM.IS_RET = 0) and&#13;&#10;      (LM.DATA_TIME_MOVE between :SD and :ED) and&#13;&#10;      (MS.UN_CODE starting with :NC))&#13;&#10;group by M.NAZVAN, K.NAZVAN, M.M_CENA&#13;&#10;order by 2, 1" UniDirectional="True" PropData="05704C65667402480470546F700394000A506172616D65746572730101061C204E616D653D225344222044617461547970653D22667444617465220001061C204E616D653D224544222044617461547970653D22667444617465220001061E204E616D653D224E43222044617461547970653D226674537472696E67220000"/>
