<TfrxReport Version="2025.2.2" DotMatrixReport="False" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="По умолчанию" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="46150,4302302546" ReportOptions.Description.Text="" ReportOptions.LastChange="46156,6066867361" ReportOptions.IsFMXReport="True" ScriptLanguage="PascalScript" ScriptText.Text="var S:String;&#13;&#10;&#13;&#10;procedure Page1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  S := &#60;WR&#62;;&#13;&#10;  qAgn.Close;&#13;&#10;  qAgn.SQL.Text := S;&#13;&#10;  qAgn.Active := true;&#13;&#10;end;&#13;&#10;&#13;&#10;procedure MasterData3OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10; qSum.Close;&#13;&#10; qSum.ParamByName('NG').Value := qAgn.FieldByName('NO_AGN').Value;&#13;&#10; qSum.ParamByName('SD').Value := &#60;DT&#62;;&#13;&#10; qSum.Active:=true;&#13;&#10;&#13;&#10; qMod.Close;&#13;&#10; qMod.ParamByName('NG').Value := qAgn.FieldByName('NO_AGN').Value;&#13;&#10; qMod.ParamByName('SD').Value := &#60;DT&#62;;&#13;&#10; qMod.Active:=true;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" PropData="">
  <TfrxDataPage Name="Data" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxFDQuery Name="qAgn" UserName="Agent" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="SELECT&#13;&#10;    AG.NO_AGN,&#13;&#10;    ST.ST_NAME,&#13;&#10;    AG.AG_NAME,&#13;&#10;    AG.AG_DOLG&#13;&#10;FROM SITY_TABLE ST&#13;&#10;   INNER JOIN AGENTS AG ON (ST.NO_ST = AG.NO_SITY)&#13;&#10;WHERE&#13;&#10;   (&#13;&#10;      (AG.NO_AGN = :NG)&#13;&#10;   )" PropData="05704C656674025C0470546F7002580A506172616D65746572730101061F204E616D653D224E47222044617461547970653D226674496E7465676572220000"/>
    <TfrxFDQuery Name="qSum" UserName="qSum" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select NAZVAN,&#13;&#10;       SUM_OF_CENA_PROD,&#13;&#10;       SUM_OF_OPLATA,&#13;&#10;       COUNT_OF_NO_MOD_SIZE,&#13;&#10;       SUM_OF_DOLGA,&#13;&#10;       SUM_PRED&#13;&#10;from RET_CHECK_AGN(:NG, :SD)" PropData="05704C6566740390000470546F70025C0A506172616D65746572730101061F204E616D653D224E47222044617461547970653D226674496E74656765722200010636204E616D653D225344222044617461547970653D22667444617465222045787072657373696F6E3D22262336303B4454262336323B220000"/>
    <TfrxFDQuery Name="qMod" UserName="qMod" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select M.NAZVAN M_NAZVAN, LP.CENA_PROD, K.NAZVAN K_NAZVAN,&#13;&#10;       count(LP.NO_LPT) COUNT_OF_NO_LPT, MS.NO_MOD&#13;&#10;from MODEL_SIZE_TABLE MS&#13;&#10;inner join LOG_PROD_TABLE LP on (MS.NO_MST = LP.NO_MOD_SIZE)&#13;&#10;inner join MODEL_TABLE M on (MS.NO_MOD = M.NO_MOD)&#13;&#10;inner join KATEGORY_TABLE K on (M.NO_KAT = K.NO_KAT)&#13;&#10;where ((LP.NO_AGN = :NG) and&#13;&#10;      (LP.DATA_PROD = :SD))&#13;&#10;group by M.NAZVAN, LP.CENA_PROD, K.NAZVAN, MS.NO_MOD&#13;&#10;order by K.NAZVAN, M.NAZVAN" PropData="05704C65667403C8000470546F7002600A506172616D65746572730101061F204E616D653D224E47222044617461547970653D226674496E74656765722200010636204E616D653D225344222044617461547970653D22667444617465222045787072657373696F6E3D22262336303B4454262336323B220000"/>
