  <TfrxDataPage Name="Data" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxFDQuery Name="qStat" UserName="Statistic" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select distinct count(LP.NO_MOD_SIZE) COUNT_OF_NO_MOD_SIZE,&#13;&#10;                KT.NAZVAN&#13;&#10;from MODEL_SIZE_TABLE MST&#13;&#10;inner join LOG_PROD_TABLE LP on (MST.NO_MST = LP.NO_MOD_SIZE)&#13;&#10;inner join MODEL_TABLE MT on (MST.NO_MOD = MT.NO_MOD)&#13;&#10;inner join KATEGORY_TABLE KT on (MT.NO_KAT = KT.NO_KAT)&#13;&#10;where ((LP.DATA_PROD between :SD and :ED) and&#13;&#10;      (MST.UN_CODE starting with :UC))&#13;&#10;group by KT.NAZVAN&#13;&#10;order by KT.NAZVAN" PropData=""/>
    <TfrxFDQuery Name="qRet" UserName="Ret" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select K.NAZVAN,&#13;&#10;       count(LR.NO_RP) COUNT_OF_NO_RP&#13;&#10;from KATEGORY_TABLE K&#13;&#10;inner join MODEL_TABLE M on (K.NO_KAT = M.NO_KAT)&#13;&#10;inner join MODEL_SIZE_TABLE MS on (M.NO_MOD = MS.NO_MOD)&#13;&#10;inner join LOG_RET_PROD LR on (MS.NO_MST = LR.NO_MODSIZ)&#13;&#10;where ((LR.DATA_RET between :SD and :ED)  and&#13;&#10;      (MS.UN_CODE starting with :UC))&#13;&#10;group by K.NAZVAN" PropData=""/>
  </TfrxDataPage>
