<TfrxReport Version="2025.2.2" DotMatrixReport="False" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="По умолчанию" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="46129,472943993" ReportOptions.Description.Text="" ReportOptions.LastChange="46129,5156842477" ReportOptions.IsFMXReport="True" ScriptLanguage="PascalScript" ScriptText.Text="var NSC: Integer;&#13;&#10;&#13;&#10;procedure MasterData1OnAfterPrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10; qSize.Close;&#13;&#10; qSize.ParamByName('NM').Value := qMod.FieldByName('NO_MOD').Value;&#13;&#10; qSize.Open;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" PropData="044C656674024803546F7002400844617461736574730101062220446174615365743D22714D6F642220446174615365744E616D653D22714D6F64220001062420446174615365743D227153697A652220446174615365744E616D653D227153697A65220000095661726961626C657301010614204E616D653D224956222056616C75653D2230220000055374796C650100">
