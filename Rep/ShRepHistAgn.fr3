<TfrxReport Version="2025.2.2" DotMatrixReport="False" PreviewOptions.Buttons="4095" PreviewOptions.Zoom="1" PrintOptions.Printer="По умолчанию" PrintOptions.PrintOnSheet="0" ReportOptions.CreateDate="46154,6011061111" ReportOptions.Description.Text="" ReportOptions.LastChange="46156,3661035417" ReportOptions.IsFMXReport="True" ScriptLanguage="PascalScript" ScriptText.Text="&#13;&#10;procedure MasterData1OnBeforePrint(Sender: TfrxComponent);&#13;&#10;begin&#13;&#10;  qDetProd.Close;&#13;&#10;  qDetProd.ParamByName('dp').Value := qHist.FieldByName('DATA_PROD').Value;&#13;&#10;  qDetProd.Active := true;&#13;&#10;&#13;&#10;  dd.Visible:=true;&#13;&#10;  ft.Visible:=true;&#13;&#10;  hd.Visible:=true;&#13;&#10;  if qHist.FieldByName('FL_OP').Value &#62;= 1 then&#13;&#10;  begin&#13;&#10;   dd.Visible:=false;&#13;&#10;   ft.Visible:=false;&#13;&#10;   hd.Visible:=false;&#13;&#10;  end;&#13;&#10;  if qHist.FieldByName('FL_OP').Value &#60;= -1 then&#13;&#10;  begin&#13;&#10;   dd.Visible:=false;&#13;&#10;   ft.Visible:=false;&#13;&#10;   hd.Visible:=false;&#13;&#10;  end;&#13;&#10;end;&#13;&#10;&#13;&#10;begin&#13;&#10;&#13;&#10;end." StoreInDFM="False" PropData="">
  <TfrxDataPage Name="Data" Height="1000" Left="0" Top="0" Width="1000">
    <TfrxFDQuery Name="qAg" UserName="Agent" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select AG.AG_NAME,&#13;&#10;       ST.ST_NAME,&#13;&#10;       AG.AG_DOLG,&#13;&#10;       AG.IS_SKIDKA,&#13;&#10;       AG.AG_PRED,&#13;&#10;       VT.NAZVAN&#13;&#10;     , AG.AG_BANK_PRED&#13;&#10;from VALUT_TABLE VT&#13;&#10;inner join AGENTS AG on (VT.NO_VAL = AG.PRED_VAL)&#13;&#10;inner join SITY_TABLE ST on (AG.NO_SITY = ST.NO_ST)&#13;&#10;where ((AG.NO_AGN = :NG))" PropData="05704C65667402640470546F7002740A506172616D657465727301010639204E616D653D224E47222044617461547970653D226674496E7465676572222045787072657373696F6E3D22262336303B4E47262336323B220000"/>
    <TfrxFDQuery Name="qHist" UserName="UsHist" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select DATA_PROD,&#13;&#10;       SUM_OF_CENA_PROD,&#13;&#10;       OPERATION,&#13;&#10;       FL_OP&#13;&#10;from LOG_DET_OP_AGN(:NG)&#13;&#10;ORDER BY 1 DESC, FL_OP asc" PropData="05704C65667403A8000470546F7002780A506172616D657465727301010639204E616D653D224E47222044617461547970653D226674496E7465676572222045787072657373696F6E3D22262336303B4E47262336323B220000"/>
    <TfrxFDQuery Name="qDetProd" UserName="DetProd" CloseDataSource="True" FieldAliases.Text="" BCDToCurrency="False" IgnoreDupParams="False" SQL.Text="select&#13;&#10;    model_table.nazvan m_nazvan,&#13;&#10;    kategory_table.nazvan k_nazvan,&#13;&#10;    count( log_prod_table.no_mod_size ) count_of_no_mod_size,&#13;&#10;    log_prod_table.cena_prod&#13;&#10;from log_prod_table&#13;&#10;   inner join model_size_table on (log_prod_table.no_mod_size = model_size_table.no_mst)&#13;&#10;   inner join model_table on (model_size_table.no_mod = model_table.no_mod)&#13;&#10;   inner join kategory_table on (model_table.no_kat = kategory_table.no_kat)&#13;&#10;where&#13;&#10;   (&#13;&#10;      (log_prod_table.data_prod = :dp)&#13;&#10;   and&#13;&#10;      (log_prod_table.no_agn = :ng)&#13;&#10;   )&#13;&#10;group by model_table.nazvan, kategory_table.nazvan, log_prod_table.cena_prod" PropData="05704C65667403E4000470546F7002740A506172616D65746572730101061C204E616D653D226470222044617461547970653D226674446174652200010639204E616D653D226E67222044617461547970653D226674496E7465676572222045787072657373696F6E3D22262336303B4E47262336323B220000"/>
